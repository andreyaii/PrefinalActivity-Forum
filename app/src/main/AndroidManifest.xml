<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    This file declares all your Activities and App permissions.
    Every Activity you create MUST be listed here, or the app will crash.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET permission: required to make any network/API calls -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrefinalProj"
        android:usesCleartextTraffic="true"> <!-- Needed for http:// URLs (not https) -->

        <!-- LoginActivity is the launcher (first screen the user sees) -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- RegisterActivity: shown when user taps "Register" -->
        <activity android:name=".activities.RegisterActivity" android:exported="false"/>

        <!-- MainActivity: the posts feed shown after login -->
        <activity android:name=".activities.MainActivity" android:exported="false"/>

        <!-- NewPostActivity: shown when user wants to write a new post -->
        <activity android:name=".activities.NewPostActivity" android:exported="false"/>

    </application>

</manifest>