<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <!-- Top bar with logout button -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💬 Forum"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Logout"
            android:textSize="13sp"
            android:textColor="#FF4444"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </LinearLayout>

    <!-- Root content area below the top bar -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp">

        <!--
            RecyclerView — the scrollable list of posts.
            clipToPadding=false + paddingBottom lets the last item
            be visible above the FAB button.
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"/>

        <!-- Shown while posts are loading on first launch -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"/>

        <!-- Shown when there are no posts at all -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No posts yet.\nBe the first to post! 🎉"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#999999"
            android:visibility="gone"/>

    </FrameLayout>

    <!--
        FAB (Floating Action Button) — always visible in the bottom-right corner.
        Tapping it opens NewPostActivity.
        app:layout_anchor + app:layout_anchorGravity positions it relative to the layout.
    -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewPost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="New Post"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="#4361EE"
        app:tint="#FFFFFF"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>